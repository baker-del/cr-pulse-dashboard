# Google OAuth 2.0 Credentials
# ─────────────────────────────────────────────────────────────────────────────
# Setup steps:
#   1. Go to https://console.cloud.google.com
#   2. Select or create a project
#   3. APIs & Services → OAuth consent screen → set to Internal (G Suite)
#   4. APIs & Services → Credentials → Create → OAuth 2.0 Client ID
#      Type: Web application
#      Authorized redirect URIs:
#        - http://localhost:8501          (for local dev)
#        - https://YOUR-NGROK-URL        (for ngrok sharing)
#   5. Copy Client ID and Secret below

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret

# Set to your current base URL (no trailing slash)
# Local:  http://localhost:8501
# ngrok:  https://abc123.ngrok-free.app
OAUTH_REDIRECT_URI=http://localhost:8501
